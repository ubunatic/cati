{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "buttons.schema.json",
  "title": "Cati Buttons",
  "description": "Button widget definitions with action bindings",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "button": {
      "type": "object",
      "required": ["text", "action"],
      "additionalProperties": false,
      "properties": {
        "text":   { "type": "string", "description": "Button label (caps from style.yaml buttons.left_cap/right_cap are applied)" },
        "style":  {
          "type": "string",
          "enum": ["primary", "secondary", "active", "muted", "info", "danger"],
          "description": "Theme token from spec/theme.yaml"
        },
        "action": {
          "type": "string",
          "description": "Registered action name mapped to a Go handler at startup",
          "enum": [
            "nav_prev",
            "nav_next",
            "open_settings",
            "open_about",
            "open_website",
            "quit",
            "go_back",
            "toggle_mode",
            "inc_zoom",
            "dec_zoom",
            "play_video",
            "pause_video",
            "save_settings",
            "cancel_settings"
          ]
        }
      }
    }
  },
  "properties": {
    "$schema": { "type": "string" },
    "buttons": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/button" }
    }
  }
}
