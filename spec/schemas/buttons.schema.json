{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "buttons.schema.json",
  "title": "Cati Buttons",
  "description": "Button widget definitions with action bindings",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "button": {
      "type": "object",
      "required": ["text", "action"],
      "additionalProperties": false,
      "properties": {
        "text":   { "type": "string", "description": "Button label (caps from style.yaml buttons.left_cap/right_cap are applied)" },
        "style":  {
          "type": "string",
          "enum": ["primary", "secondary", "active", "muted", "info", "danger"],
          "description": "Theme token from spec/theme.yaml"
        },
        "keys": {
          "type": "array",
          "description": "Keys that trigger this button's action. Use named aliases: <esc>, <cr>, <space>, <tab>, <bs>, <up>, <down>, <left>, <right>, <pgup>, <pgdn>, <c-c>, <c-d>, … or plain chars like \"q\", \"[\".",
          "items": { "type": "string" }
        },
        "alt_action": {
          "type": "string",
          "description": "Optional secondary action for alt_keys (e.g. reverse direction of a cycle).",
          "enum": [
            "nav_prev",
            "nav_next",
            "open_settings",
            "open_about",
            "open_website",
            "quit",
            "go_back",
            "toggle_mode",
            "inc_zoom",
            "dec_zoom",
            "save_settings",
            "cancel_settings",
            "toggle_pan",
            "copy_viewport",
            "toggle_play_pause",
            "nav_up",
            "nav_down",
            "nav_page_prev",
            "nav_page_next",
            "cycle_render",
            "cycle_render_prev",
            "toggle_halfblock"
          ]
        },
        "alt_keys": {
          "type": "array",
          "description": "Keys that trigger alt_action instead of action.",
          "items": { "type": "string" }
        },
        "action": {
          "type": "string",
          "description": "Registered action name mapped to a Go handler at startup",
          "enum": [
            "nav_prev",
            "nav_next",
            "open_settings",
            "open_about",
            "open_website",
            "quit",
            "go_back",
            "toggle_mode",
            "inc_zoom",
            "dec_zoom",
            "save_settings",
            "cancel_settings",
            "toggle_pan",
            "copy_viewport",
            "toggle_play_pause",
            "nav_up",
            "nav_down",
            "nav_page_prev",
            "nav_page_next",
            "cycle_render",
            "cycle_render_prev",
            "toggle_halfblock"
          ]
        }
      }
    }
  },
  "properties": {
    "$schema": { "type": "string" },
    "buttons": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/button" }
    }
  }
}
